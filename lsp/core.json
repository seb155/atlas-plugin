{
  "lspServers": {
    "yaml-language-server": {
      "command": "yaml-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".yaml": "yaml",
        ".yml": "yaml"
      },
      "transport": "stdio",
      "settings": {
        "yaml": {
          "validate": true,
          "hover": true,
          "completion": true,
          "format": {
            "enable": true
          }
        }
      }
    }
  }
}
