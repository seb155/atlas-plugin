#!/bin/bash
# session-state-writer — Persist session state for auto-resume
# Event: PostToolUse(TaskUpdate) — updates state when tasks change
# Also called by: session-start (read), session-retrospective (finalize)
#
# State file: ~/.claude/session-state.json
# Used by: session-start hook (auto-resume), atlas status CLI, SP-IDP dashboard

set -euo pipefail
trap 'exit 0' ERR

STATE_FILE="${HOME}/.claude/session-state.json"

# ── Read input ────────────────────────────────────────────────
INPUT=$(cat 2>/dev/null || echo '{}')
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null)

# Only trigger on TaskUpdate (status changes indicate session progress)
case "$TOOL" in
  TaskUpdate|TaskCreate) ;;
  *) exit 0 ;;
esac

# ── Build state from current task list ────────────────────────
# Parse TaskUpdate input for task status
TASK_ID=$(echo "$INPUT" | jq -r '.tool_input.taskId // empty' 2>/dev/null)
NEW_STATUS=$(echo "$INPUT" | jq -r '.tool_input.status // empty' 2>/dev/null)

# Read existing state
EXISTING="{}"
[ -f "$STATE_FILE" ] && EXISTING=$(cat "$STATE_FILE" 2>/dev/null || echo "{}")

# Update state
python3 -c "
import json, os
from datetime import datetime

state_file = '$STATE_FILE'
existing = {}
try:
    with open(state_file) as f:
        existing = json.load(f)
except:
    pass

# Update fields
existing['last_activity'] = datetime.now().isoformat()
existing['session_id'] = existing.get('session_id', datetime.now().strftime('%Y-%m-%d_%H:%M'))

# Track task progress
task_id = '$TASK_ID'
new_status = '$NEW_STATUS'
if task_id and new_status:
    tasks = existing.get('tasks', {})
    tasks[task_id] = new_status
    existing['tasks'] = tasks

    # Count progress
    completed = sum(1 for s in tasks.values() if s == 'completed')
    total = len(tasks)
    existing['progress'] = f'{completed}/{total}'

# Detect active plan from CWD
cwd = os.getcwd()
if '.blueprint/plans/' in cwd or os.path.exists('.blueprint/plans/'):
    # Try to find the most recently modified plan
    plans_dir = '.blueprint/plans/'
    if os.path.isdir(plans_dir):
        plans = [(os.path.getmtime(os.path.join(plans_dir, f)), f)
                 for f in os.listdir(plans_dir)
                 if f.endswith('.md') and f.startswith('sp')]
        if plans:
            plans.sort(reverse=True)
            existing['active_plan'] = plans[0][1]

# Git info
import subprocess
try:
    branch = subprocess.check_output(['git', 'branch', '--show-current'],
                                      stderr=subprocess.DEVNULL, text=True).strip()
    existing['branch'] = branch
except:
    pass

# Worktree detection
try:
    toplevel = subprocess.check_output(['git', 'rev-parse', '--show-toplevel'],
                                        stderr=subprocess.DEVNULL, text=True).strip()
    if '.claude/worktrees/' in toplevel or '.worktrees/' in toplevel:
        existing['worktree'] = os.path.basename(toplevel)
except:
    pass

with open(state_file, 'w') as f:
    json.dump(existing, f, indent=2)
" 2>/dev/null || true

exit 0
