#!/bin/bash
# Auto-cleanup stale Claude Code worktrees on session end
# Only cleans .claude/worktrees/ (CC-managed), NOT .worktrees/ (manual/project)
# Safe: skips worktrees with uncommitted changes or unique commits

# Hook aggregation log
_hook_log() {
  local result="${1:-pass}"
  local elapsed="${2:-0}"
  printf '{"ts":"%s","event":"%s","handler":"%s","result":"%s","ms":%s}\n' \
    "$(date -Iseconds)" "${HOOK_EVENT:-Stop}" "$(basename "$0")" "$result" "$elapsed" \
    >> "${HOME}/.claude/hook-log.jsonl" 2>/dev/null
}

WORKSPACE="${HOME}/workspace_atlas"
CLEANED=0
KEPT=0

for repo_dir in $(find "$WORKSPACE" -maxdepth 4 -name ".claude" -type d 2>/dev/null); do
  wt_dir="$repo_dir/worktrees"
  [ -d "$wt_dir" ] || continue

  repo_root="$(dirname "$repo_dir")"
  [ -d "$repo_root/.git" ] || continue

  for wt in "$wt_dir"/*/; do
    [ -d "$wt" ] || continue
    name=$(basename "$wt")

    # Skip if dirty (uncommitted changes)
    dirty=$(cd "$wt" && git status --porcelain 2>/dev/null | wc -l)
    if [ "$dirty" -gt 0 ]; then
      KEPT=$((KEPT + 1))
      continue
    fi

    # Skip if has unique commits not in main or dev
    ahead_main=$(cd "$wt" && git log main..HEAD --oneline 2>/dev/null | wc -l)
    ahead_dev=$(cd "$wt" && git log dev..HEAD --oneline 2>/dev/null | wc -l)
    if [ "$ahead_main" -gt 0 ] && [ "$ahead_dev" -gt 0 ]; then
      KEPT=$((KEPT + 1))
      continue
    fi

    # Safe to remove
    cd "$repo_root" || continue
    git worktree remove "$wt" --force 2>/dev/null
    git branch -D "$name" 2>/dev/null
    git branch -D "worktree-$name" 2>/dev/null
    CLEANED=$((CLEANED + 1))
  done

  cd "$repo_root" && git worktree prune 2>/dev/null
done

[ "$CLEANED" -gt 0 ] && echo "🧹 Cleaned $CLEANED stale worktree(s), kept $KEPT with work"
_hook_log pass
exit 0
