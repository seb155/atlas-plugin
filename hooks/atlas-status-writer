#!/usr/bin/env bash
# ATLAS Plugin — UserPromptSubmit hook
# Refreshes session-state.json for CShip/Starship status line consumption
# Runs async (does NOT block user prompt). Must complete in <5s.
#
# Cache strategy:
#   Features: always recalculated (~2ms awk)
#   Docker:   30s cache (docker ps)
#   CI:       60s cache (Forgejo API, 2s timeout)
#   Tier:     read from existing state (set at SessionStart)
set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
STATE_FILE="${CLAUDE_PLUGIN_DATA:-$HOME/.claude}/session-state.json"

# Read value from ~/.atlas/config.json with fallback
atlas_config() {
  local key="$1" fallback="${2:-}"
  python3 -c "
import json, os
try:
    with open(os.path.expanduser('~/.atlas/config.json')) as f:
        d = json.load(f)
    keys = '$key'.split('.')
    v = d
    for k in keys: v = v[k]
    if isinstance(v, list): print(' '.join(v))
    else: print(v)
except: print('$fallback')
" 2>/dev/null || echo "$fallback"
}

# Bail fast if no state file exists (CShip not configured / first session)
[ -f "$STATE_FILE" ] || exit 0

NOW=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
NOW_EPOCH=$(date +%s)

# Read existing state once
EXISTING=$(cat "$STATE_FILE" 2>/dev/null || echo '{}')

# Helper: check if a cached timestamp is still valid
# Usage: cache_valid "$checked_at" $ttl_seconds
cache_valid() {
  local checked_at="$1"
  local ttl="$2"
  [ -z "$checked_at" ] && return 1
  local checked_epoch
  checked_epoch=$(date -d "${checked_at}" +%s 2>/dev/null || echo 0)
  [ $((NOW_EPOCH - checked_epoch)) -lt "$ttl" ]
}

# --- Tier (from existing state, never changes mid-session) ---
TIER=$(echo "$EXISTING" | jq -r '.tier // "?"' 2>/dev/null || echo "?")
VERSION=$(cat "${PLUGIN_ROOT}/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "?")
HOSTNAME_SHORT=$(echo "$EXISTING" | jq -r '.hostname // "?"' 2>/dev/null || echo "?")

# --- Features (always recalculate, ~2ms) ---
FEAT_TOTAL=0; FEAT_ACTIVE=0; FEAT_DONE=0
if [ -f ".blueprint/FEATURES.md" ]; then
  eval "$(awk '/^## Feature:/{t++} /IN_PROGRESS/{a++} /DONE/{d++} END{printf "FEAT_TOTAL=%d FEAT_ACTIVE=%d FEAT_DONE=%d",t,a,d}' ".blueprint/FEATURES.md" 2>/dev/null)" || true
fi

# --- Docker (30s cache) ---
DOCKER_CHECKED=$(echo "$EXISTING" | jq -r '.docker.checked_at // ""' 2>/dev/null || echo "")
if cache_valid "$DOCKER_CHECKED" 30; then
  DOCKER_JSON=$(echo "$EXISTING" | jq -c '.docker' 2>/dev/null || echo '{"available":false,"containers":0}')
else
  if [ "$HOSTNAME_SHORT" = "ATL-dev" ] || ! command -v docker &>/dev/null; then
    DOCKER_JSON="{\"available\":false,\"containers\":0,\"checked_at\":\"${NOW}\"}"
  else
    local_count=$(docker ps --filter name=synapse -q 2>/dev/null | wc -l | tr -d ' ')
    DOCKER_JSON="{\"available\":true,\"containers\":${local_count},\"checked_at\":\"${NOW}\"}"
  fi
fi

# --- CI (60s cache) ---
CI_CHECKED=$(echo "$EXISTING" | jq -r '.ci.checked_at // ""' 2>/dev/null || echo "")
if cache_valid "$CI_CHECKED" 60; then
  CI_JSON=$(echo "$EXISTING" | jq -c '.ci' 2>/dev/null || echo '{"status":"unknown"}')
else
  BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
  CI_STATUS="unknown"

  # Try Forgejo API (local URL, 2s timeout)
  if [ -f "$HOME/.env" ]; then
    # shellcheck disable=SC1091
    source "$HOME/.env" 2>/dev/null || true
  fi
  if [ -n "${FORGEJO_TOKEN:-}" ]; then
    forgejo_api_url=$(atlas_config "services.forgejo.local_url" "")
    forgejo_owner=$(atlas_config "services.forgejo.owner" "atlas")
    forgejo_repo=$(atlas_config "services.forgejo.repo" "synapse")
    forgejo_api_path=$(atlas_config "services.forgejo.api_path" "/api/v1")
    CI_STATUS=$(curl -sf --max-time 2 \
      "${forgejo_api_url}${forgejo_api_path}/repos/${forgejo_owner}/${forgejo_repo}/commits/${BRANCH}/status" \
      -H "Authorization: token ${FORGEJO_TOKEN}" 2>/dev/null \
      | jq -r '.state // "unknown"' 2>/dev/null || echo "unreachable")
  fi
  CI_JSON="{\"status\":\"${CI_STATUS}\",\"branch\":\"${BRANCH}\",\"checked_at\":\"${NOW}\"}"
fi

# --- Write updated state atomically ---
TEMP_FILE="${STATE_FILE}.tmp.$$"
cat > "$TEMP_FILE" <<STATEEOF
{"version":1,"updated_at":"${NOW}","tier":"${TIER}","plugin_version":"${VERSION}","hostname":"${HOSTNAME_SHORT}","docker":${DOCKER_JSON},"ci":${CI_JSON},"features":{"total":${FEAT_TOTAL},"active":${FEAT_ACTIVE},"done":${FEAT_DONE},"checked_at":"${NOW}"}}
STATEEOF
mv "$TEMP_FILE" "$STATE_FILE"
