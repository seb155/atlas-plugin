#!/usr/bin/env bash
# ATLAS Plugin — PostToolUse Heartbeat
# Fires after every tool call to increment tool_call_count in session tracking
# Exit 0 = OK (never block)

INPUT=$(cat 2>/dev/null || true)
SESSION_ID=$(echo "$INPUT" | jq -r '.session_id // empty' 2>/dev/null)

# No session_id → nothing to report
[ -z "$SESSION_ID" ] && exit 0

SYNAPSE_API="${SYNAPSE_API_URL:-http://localhost:8001/api/v1}"

curl -sf --max-time 2 -X POST "${SYNAPSE_API}/hooks/atlas/sessions/heartbeat" \
  -H "Content-Type: application/json" \
  -H "X-Atlas-Token: ${ATLAS_HOOKS_TOKEN:-}" \
  -d "{
    \"session_id\": \"${SESSION_ID}\",
    \"tool_count_delta\": 1
  }" >/dev/null 2>&1 || true

exit 0
