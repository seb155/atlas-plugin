#!/usr/bin/env bash
# ATLAS Plugin — Session Start Hook
# Injects the tier-appropriate atlas-assist skill into every Claude Code session
# Detects user role via: Authentik API → ATLAS_ROLE env var → plugin default

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
SKILL_FILE="${PLUGIN_ROOT}/skills/atlas-assist/SKILL.md"
AUDIT_LOG="${HOME}/.claude/atlas-audit.log"

# Detect the plugin's built-in tier from plugin.json
detect_plugin_tier() {
  local plugin_name
  plugin_name=$(cat "${PLUGIN_ROOT}/.claude-plugin/plugin.json" 2>/dev/null \
    | grep -o '"name": *"[^"]*"' | head -1 | sed 's/.*"name": *"atlas-\?\([^"]*\)".*/\1/')

  case "$plugin_name" in
    admin|dev|user) echo "$plugin_name" ;;
    *) echo "dev" ;;  # Default to dev for legacy "atlas" plugin name
  esac
}

# Detect user role from Authentik or environment
detect_role() {
  local source="default"
  local role=""
  local details=""

  # Priority 1: Authentik API (if token available)
  if [ -n "${AUTHENTIK_TOKEN:-}" ]; then
    local groups
    groups=$(curl -sf --max-time 3 \
      "${AUTHENTIK_URL:-https://auth.home.axoiq.com}/api/v3/core/users/me/" \
      -H "Authorization: Bearer $AUTHENTIK_TOKEN" \
      | grep -o '"name":"[^"]*"' | sed 's/"name":"//;s/"//' 2>/dev/null || true)

    if [ -n "$groups" ]; then
      source="authentik"
      if echo "$groups" | grep -q "axoiq-admins"; then
        role="admin"; details="group=axoiq-admins"
      elif echo "$groups" | grep -q "axoiq-devs"; then
        role="dev"; details="group=axoiq-devs"
      else
        role="user"; details="group=other"
      fi
    fi
  fi

  # Priority 2: ATLAS_ROLE env var
  if [ -z "$role" ] && [ -n "${ATLAS_ROLE:-}" ]; then
    source="env_var"
    role="${ATLAS_ROLE}"
    details="ATLAS_ROLE=${ATLAS_ROLE}"
  fi

  # Priority 3: Plugin's built-in tier
  if [ -z "$role" ]; then
    source="plugin_tier"
    role=$(detect_plugin_tier)
    details="plugin=$(basename "$PLUGIN_ROOT")"
  fi

  # Audit log
  local ts
  ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  local plugin_tier
  plugin_tier=$(detect_plugin_tier)
  local version
  version=$(cat "${PLUGIN_ROOT}/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")
  mkdir -p "$(dirname "$AUDIT_LOG")"
  echo "${ts} | tier=${role} | source=${source} | ${details} | plugin=atlas-${plugin_tier}@${version}" >> "$AUDIT_LOG"

  # Check for tier mismatch
  if [ "$source" = "authentik" ] && [ "$role" != "$plugin_tier" ]; then
    # User's Authentik role doesn't match installed plugin tier
    TIER_WARNING="⚠️ TIER MISMATCH: Your Authentik role is '${role}' but you have atlas-${plugin_tier} installed. Consider installing atlas-${role} for the best experience."
  fi

  echo "$role"
}

# Main — SessionStart hook: role detection + audit log + feature summary
# Skills are loaded on-demand by CC's skill system, NOT injected here.
TIER_WARNING=""
DETECTED_ROLE=$(detect_role)

# Feature Board summary injection (if FEATURES.md exists in current project)
FEATURE_SUMMARY=""
PARSE_SCRIPT="${PLUGIN_ROOT}/scripts/parse-features.sh"
if [ -f ".blueprint/FEATURES.md" ] && [ -x "$PARSE_SCRIPT" ]; then
  FEATURE_SUMMARY=$("$PARSE_SCRIPT" ".blueprint/FEATURES.md" 2>/dev/null || true)
fi

# Report session to Synapse API (fire-and-forget)
SYNAPSE_API="${SYNAPSE_API_URL:-http://localhost:8001/api/v1}"
SESSION_ID="${CLAUDE_SESSION_ID:-$(date +%s)-$$}"
BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
MODEL="${CLAUDE_MODEL:-unknown}"
USER_EMAIL="${USER_EMAIL:-${EMAIL:-unknown}}"
# Extract feature ID from branch name (feature/FEAT-001-xxx → FEAT-001)
FEATURE_ID=$(echo "$BRANCH" | grep -oP 'FEAT-\d+' 2>/dev/null || true)

curl -sf --max-time 3 -X POST "${SYNAPSE_API}/hooks/atlas/sessions/start" \
  -H "Content-Type: application/json" \
  -H "X-Atlas-Token: ${ATLAS_HOOKS_TOKEN:-}" \
  -d "{
    \"session_id\": \"${SESSION_ID}\",
    \"user_email\": \"${USER_EMAIL}\",
    \"model\": \"${MODEL}\",
    \"branch\": \"${BRANCH}\",
    \"feature_id\": \"${FEATURE_ID}\",
    \"cwd\": \"$(pwd)\"
  }" >/dev/null 2>&1 &

# Fetch mini-brief from Synapse PA API (if available)
BRIEF_CONTEXT=""
if [ -n "${SYNAPSE_API:-}" ]; then
  # Get a JWT token first (use service account or skip if no auth)
  BRIEF_JSON=$(curl -sf --max-time 3 "${SYNAPSE_API}/pa/brief" \
    -H "Authorization: Bearer ${SYNAPSE_TOKEN:-}" 2>/dev/null || true)
  if [ -n "$BRIEF_JSON" ]; then
    # Extract key counts for compact injection
    ACTIVE_SESSIONS=$(echo "$BRIEF_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('active_sessions',[])))" 2>/dev/null || echo "0")
    ACTIVE_FEATURES=$(echo "$BRIEF_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('feature_summary',[])))" 2>/dev/null || echo "0")
    OPEN_TASKS=$(echo "$BRIEF_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('recent_tasks',[])))" 2>/dev/null || echo "0")
    BRIEF_CONTEXT="ATLAS BRIEF: ${ACTIVE_SESSIONS} active sessions, ${ACTIVE_FEATURES} features in progress, ${OPEN_TASKS} open tasks."
  fi
fi

# Combine all context
ALL_CONTEXT=""
[ -n "$FEATURE_SUMMARY" ] && ALL_CONTEXT="${FEATURE_SUMMARY}"
[ -n "$BRIEF_CONTEXT" ] && ALL_CONTEXT="${ALL_CONTEXT}\n${BRIEF_CONTEXT}"
[ -n "$TIER_WARNING" ] && ALL_CONTEXT="${ALL_CONTEXT}\n${TIER_WARNING}"

# Output with optional context
if [ -n "$ALL_CONTEXT" ]; then
  ESCAPED=$(echo -e "$ALL_CONTEXT" | sed ':a;N;$!ba;s/\n/\\n/g;s/"/\\"/g')
  echo "{\"continue\": true, \"additionalContext\": \"${ESCAPED}\"}"
else
  echo '{"continue": true}'
fi
