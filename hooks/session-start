#!/usr/bin/env bash
# ATLAS Plugin — Session Start Hook
# Injects the using-atlas skill into every Claude Code session

SKILL_FILE="${CLAUDE_PLUGIN_ROOT}/skills/using-atlas/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
  echo '{"additionalContext": "ATLAS plugin: skill file not found"}'
  exit 0
fi

# Read and escape the skill content for JSON injection
SKILL_CONTENT=$(cat "$SKILL_FILE" | sed 's/\\/\\\\/g' | sed 's/"/\\"/g' | sed ':a;N;$!ba;s/\n/\\n/g')

cat <<EOF
{
  "additionalContext": "<ATLAS_PLUGIN>\n${SKILL_CONTENT}\n</ATLAS_PLUGIN>"
}
EOF
