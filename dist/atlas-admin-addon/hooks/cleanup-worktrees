#!/bin/bash
# Auto-cleanup stale Claude Code worktrees on session end
# Only cleans .claude/worktrees/ (CC-managed), NOT .worktrees/ (manual/project)
# Safe: skips worktrees with uncommitted changes or unique commits
# Enhanced: age warnings + auto-merge-back proposals
set -euo pipefail

# Hook aggregation log
_hook_log() {
  local result="${1:-pass}"
  local elapsed="${2:-0}"
  printf '{"ts":"%s","event":"%s","handler":"%s","result":"%s","ms":%s}\n' \
    "$(date -Iseconds)" "${HOOK_EVENT:-Stop}" "$(basename "$0")" "$result" "$elapsed" \
    >> "${HOME}/.claude/hook-log.jsonl" 2>/dev/null
}

WORKSPACE="${ATLAS_WORKSPACE_ROOT:-$HOME}"
CLEANED=0
KEPT=0
AGED=0
MERGE_CANDIDATES=""
AGE_WARN_DAYS=7
NOW_EPOCH=$(date +%s)

for repo_dir in $(find "$WORKSPACE" -maxdepth 4 -name ".claude" -type d 2>/dev/null || true); do
  wt_dir="$repo_dir/worktrees"
  [ -d "$wt_dir" ] || continue

  repo_root="$(dirname "$repo_dir")"
  [ -d "$repo_root/.git" ] || continue

  for wt in "$wt_dir"/*/; do
    [ -d "$wt" ] || continue
    name=$(basename "$wt")

    # Check age (days since last commit in worktree)
    last_commit_epoch=$(cd "$wt" && git log -1 --format=%ct HEAD 2>/dev/null || echo "$NOW_EPOCH") || last_commit_epoch="$NOW_EPOCH"
    age_days=$(( (NOW_EPOCH - last_commit_epoch) / 86400 ))

    # Skip if dirty (uncommitted changes) — exclude known ephemeral files
    # Note: || true on each grep — empty input makes grep exit 1, which breaks pipefail
    dirty=$(cd "$wt" && git status --porcelain 2>/dev/null \
      | { grep -v '^?? \.blueprint/plans/' || true; } \
      | { grep -v '^?? \.claude/' || true; } \
      | { grep -v '^?? memory/' || true; } \
      | { grep -v '^?? node_modules/' || true; } \
      | wc -l)
    if [ "$dirty" -gt 0 ]; then
      KEPT=$((KEPT + 1))
      # Age warning for dirty worktrees
      if [ "$age_days" -ge "$AGE_WARN_DAYS" ]; then
        AGED=$((AGED + 1))
      fi
      continue
    fi

    # Check if has unique commits not in main or dev
    # Note: git log can fail if main/dev ref doesn't exist locally — wrap with || true
    ahead_main=$( (cd "$wt" && git log main..HEAD --oneline 2>/dev/null || true) | wc -l)
    ahead_dev=$( (cd "$wt" && git log dev..HEAD --oneline 2>/dev/null || true) | wc -l)

    # v6.1.0 bug fix: condition was && (AND) which required ahead of BOTH main AND dev.
    # Repos without a local `dev` branch (e.g., atlas-plugin which uses main-only workflow)
    # always had ahead_dev=0, making the AND always false, causing active worktrees with
    # 5+ commits ahead of main to be wiped mid-session. Fix: OR (||) — keep if unique
    # commits exist vs EITHER trunk. Also handles refname aliases (dev may be trunk).
    if [ "$ahead_main" -gt 0 ] || [ "$ahead_dev" -gt 0 ]; then
      KEPT=$((KEPT + 1))
      # Clean worktree with unique commits → merge candidate
      # Show whichever ref has the larger ahead count (more informative)
      ahead_max=$ahead_main
      trunk_label="main"
      if [ "$ahead_dev" -gt "$ahead_main" ]; then
        ahead_max=$ahead_dev
        trunk_label="dev"
      fi
      MERGE_CANDIDATES="${MERGE_CANDIDATES}  ${name} (${ahead_max} commits ahead of ${trunk_label}, ${age_days}d old)\n"
      if [ "$age_days" -ge "$AGE_WARN_DAYS" ]; then
        AGED=$((AGED + 1))
      fi
      continue
    fi

    # Safe to remove (clean + no unique commits)
    cd "$repo_root" || continue
    git worktree remove "$wt" --force 2>/dev/null || true
    # Try both naming conventions for branch cleanup
    git branch -D "$name" 2>/dev/null || true
    git branch -D "worktree-$name" 2>/dev/null || true
    CLEANED=$((CLEANED + 1))
  done

  cd "$repo_root" && git worktree prune 2>/dev/null || true
done

# Summary output
[ "$CLEANED" -gt 0 ] && echo "🧹 Cleaned $CLEANED stale worktree(s), kept $KEPT with work"
[ "$AGED" -gt 0 ] && echo "⚠️ $AGED worktree(s) older than ${AGE_WARN_DAYS} days — consider merging or removing"
if [ -n "$MERGE_CANDIDATES" ]; then
  echo "💡 Merge candidates (clean, ahead of dev):"
  echo -e "$MERGE_CANDIDATES"
fi

_hook_log pass
exit 0
