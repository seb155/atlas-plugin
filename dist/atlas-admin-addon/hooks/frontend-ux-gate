#!/bin/bash
# frontend-ux-gate — Detect UI file edits and remind to brainstorm first.
#
# PostToolUse hook for Write|Edit on frontend files.
# Checks if the file is a UI component/page and the brainstorming skill
# hasn't been invoked in this session.
set -euo pipefail

# Throttle: max 1 reminder per session (5 min cooldown)
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$HOOK_DIR/lib/throttle.sh" 2>/dev/null || true

FILE_PATH="${CLAUDE_TOOL_INPUT_FILE_PATH:-${CLAUDE_TOOL_INPUT_file_path:-}}"

# Skip if no file path (shouldn't happen for Write|Edit)
[ -z "$FILE_PATH" ] && exit 0

# Only trigger for frontend UI files
case "$FILE_PATH" in
  */frontend/src/pages/*|*/frontend/src/components/*|*/atlas-components/src/*)
    ;;
  *)
    exit 0  # Not a UI file, skip
    ;;
esac

# Skip for test files, types, and config files
case "$FILE_PATH" in
  *.test.tsx|*.test.ts|*/types/*|*/lib/query/*|*config*|*index.ts)
    exit 0
    ;;
esac

# Output a gentle reminder — throttled to 1 per 5 minutes
if type throttle_check &>/dev/null && throttle_check "ux-gate" 300; then
  echo "UI file detected: $(basename "$FILE_PATH"). If you haven't discussed UX architecture with the user (where this lives, what to reuse, who consumes it), invoke the frontend-workflow or brainstorming skill first. Skip this reminder if design was already approved."
fi
