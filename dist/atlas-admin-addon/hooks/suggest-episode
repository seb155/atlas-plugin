#!/usr/bin/env bash
# suggest-episode — Suggest creating an episode at session end
# Fires on Stop event. Checks: no episode today → suggests creation.
# Non-blocking, async. Exit 0 always.

set -euo pipefail

# Hook aggregation log
_hook_log() {
  local result="${1:-pass}"
  local elapsed="${2:-0}"
  printf '{"ts":"%s","event":"%s","handler":"%s","result":"%s","ms":%s}\n' \
    "$(date -Iseconds)" "${HOOK_EVENT:-Stop}" "$(basename "$0")" "$result" "$elapsed" \
    >> "${HOME}/.claude/hook-log.jsonl" 2>/dev/null
}

# Find memory dir for current project (first match with MEMORY.md)
MEMORY_DIR=""
for d in "${HOME}/.claude/projects"/*/memory; do
  [ -f "$d/MEMORY.md" ] && MEMORY_DIR="$d" && break
done
[ -z "$MEMORY_DIR" ] && _hook_log pass && exit 0

# Check if episode already exists today
TODAY=$(date +%Y-%m-%d)
if ls "${MEMORY_DIR}/episode-${TODAY}"*.md 2>/dev/null | grep -q .; then
  _hook_log pass
  exit 0  # Already has episode today
fi

# Suggest episode creation
cat << 'EOF'
📝 Session terminée. Pas d'épisode aujourd'hui.
   Créer un épisode? → /atlas episode create
EOF

_hook_log pass
