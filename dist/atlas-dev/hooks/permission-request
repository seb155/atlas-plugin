#!/usr/bin/env bash
# ATLAS Plugin — PermissionRequest Hook
# Logs and annotates permission requests with contextual warnings
# stdout → shown to user alongside the permission prompt
# Exit 0 = OK (never block the permission flow itself)

set -euo pipefail

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // "unknown"')
COMMAND=$(echo "$INPUT" | jq -r '.command // empty')
TIMESTAMP=$(date '+%H:%M')

# --- Log permission request ---
LOG_FILE="$HOME/.claude/permission-log.txt"
echo "[$TIMESTAMP] Permission: $TOOL $(echo "$COMMAND" | head -c 80)" >> "$LOG_FILE"

# --- Contextual warnings for dangerous commands ---
case "$TOOL" in
  Bash)
    if echo "$COMMAND" | grep -qiE '(rm -rf|docker (rm|rmi|system prune)|git (reset --hard|push.*force|clean -fd))'; then
      echo "🏛️ ATLAS │ ⚠️🛑 DESTRUCTIVE │ Dangerous command detected"
      echo "   └─ Review carefully before approving"
    fi
    ;;
esac

exit 0
