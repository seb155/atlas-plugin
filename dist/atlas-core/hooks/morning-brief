#!/usr/bin/env bash
# ATLAS Plugin — Predictive Morning Brief (SessionStart)
# SP-COGNITION Gap 1: Anticipation (Predictive Brain)
#
# Predicts session focus from: day-of-week patterns, recent handoffs,
# last episode energy, active intuitions. Presents contextual brief.
# Only fires on "startup" (not compact/resume).
#
# Output: system-reminder with predicted focus + context.

set -o pipefail
trap 'exit 0' ERR

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. Resolve memory directory
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Find project memory directory matching current working directory
CWD=$(pwd)
MEMORY_DIR=""
for d in ~/.claude/projects/*/memory; do
  # Extract project path from dir name
  proj_path=$(basename "$(dirname "$d")" | sed 's/^-/\//' | sed 's/-/\//g')
  if echo "$CWD" | grep -q "$(echo "$proj_path" | head -c 30)"; then
    MEMORY_DIR="$d"
    break
  fi
done

# Fallback: use the synapse memory dir explicitly
if [ -z "$MEMORY_DIR" ] || [ ! -d "$MEMORY_DIR" ]; then
  MEMORY_DIR=$(find ~/.claude/projects -path "*/memory/MEMORY.md" -printf "%h\n" 2>/dev/null | head -1)
fi

[ -z "$MEMORY_DIR" ] && exit 0
[ ! -f "$MEMORY_DIR/MEMORY.md" ] && exit 0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. Gather context signals
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

HOUR=$(date +%H)
DOW=$(date +%u)  # 1=Monday, 7=Sunday
DOW_NAME=$(date +%A)
DATE_TODAY=$(date +%Y-%m-%d)

# Last episode energy
LAST_ENERGY=4
LAST_EPISODE=$(find "$MEMORY_DIR" -name "episode-*.md" -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | awk '{print $2}')
if [ -n "$LAST_EPISODE" ] && [ -f "$LAST_EPISODE" ]; then
  LAST_ENERGY=$(grep "^energy:" "$LAST_EPISODE" 2>/dev/null | awk '{print $2}' || echo 4)
fi

# Active intuitions count
INTUITION_COUNT=$(find "$MEMORY_DIR" -name "intuition-*.md" -exec grep -l "validated: false" {} \; 2>/dev/null | wc -l)

# Last dream health score
DREAM_SCORE="?"
DREAM_HISTORY="$MEMORY_DIR/dream-history.jsonl"
if [ -f "$DREAM_HISTORY" ]; then
  DREAM_SCORE=$(tail -1 "$DREAM_HISTORY" | python3 -c "import sys,json; print(json.load(sys.stdin).get('score','?'))" 2>/dev/null || echo "?")
fi

# Recent handoffs (last 3 days)
RECENT_HANDOFFS=$(find "$MEMORY_DIR" -name "handoff-*.md" -mtime -3 2>/dev/null | wc -l)

# Sessions since last dream
LAST_DREAM_TS=$(tail -1 "$DREAM_HISTORY" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('timestamp',''))" 2>/dev/null || echo "")

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. Predict focus (pattern-based)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Read ACTIVE WORK section for current priorities
ACTIVE_ITEMS=$(python3 -c "
import re
with open('$MEMORY_DIR/MEMORY.md') as f:
    content = f.read()
# Extract bold items from ACTIVE WORK table (high priority)
bold_items = re.findall(r'\| \*\*(.+?)\*\* \|', content)
for item in bold_items[:5]:
    # Extract just the topic name
    topic = item.split('|')[0].strip().rstrip('*').lstrip('*')
    print(topic)
" 2>/dev/null || echo "")

# Most recent handoff topic (strongest signal)
LAST_HANDOFF_TOPIC=""
LAST_HANDOFF=$(find "$MEMORY_DIR" -name "handoff-*.md" -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | awk '{print $2}')
if [ -n "$LAST_HANDOFF" ]; then
  LAST_HANDOFF_TOPIC=$(grep "^description:" "$LAST_HANDOFF" 2>/dev/null | head -1 | sed 's/description: //' | head -c 80)
fi

# Energy-based time estimate
if [ "$HOUR" -ge 6 ] && [ "$HOUR" -lt 12 ]; then
  ENERGY_EST="high (morning)"
elif [ "$HOUR" -ge 12 ] && [ "$HOUR" -lt 18 ]; then
  ENERGY_EST="moderate (afternoon)"
elif [ "$HOUR" -ge 18 ] && [ "$HOUR" -lt 22 ]; then
  ENERGY_EST="moderate-low (evening)"
else
  ENERGY_EST="low (late night)"
fi

# Self-model known biases (load if exists)
BIASES_REMINDER=""
if [ -f "$MEMORY_DIR/self-model.md" ]; then
  # Extract top 3 biases
  BIASES_REMINDER=$(grep "^\| [0-9]" "$MEMORY_DIR/self-model.md" 2>/dev/null | head -3 | awk -F'|' '{print $3}' | tr -d '*' | sed 's/^ //' | head -c 200)
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. Generate brief
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

BRIEF="🧠 Morning Brief"
BRIEF="$BRIEF | $DOW_NAME $DATE_TODAY $(date +%H:%M)"
BRIEF="$BRIEF | Energy: $ENERGY_EST (last episode: $LAST_ENERGY/5)"

if [ -n "$LAST_HANDOFF_TOPIC" ]; then
  BRIEF="$BRIEF | Last session: $LAST_HANDOFF_TOPIC"
fi

if [ "$INTUITION_COUNT" -gt 0 ]; then
  BRIEF="$BRIEF | $INTUITION_COUNT open intuition(s)"
fi

BRIEF="$BRIEF | Health: $DREAM_SCORE/10 | $RECENT_HANDOFFS handoffs (3d)"

# Log prediction for accuracy tracking
PREDICTION_LOG="$HOME/.claude/atlas-prediction-log.json"
python3 -c "
import json, os
from datetime import datetime
entry = {
    'date': '$DATE_TODAY',
    'hour': $HOUR,
    'dow': $DOW,
    'predicted_energy': '$ENERGY_EST',
    'last_episode_energy': $LAST_ENERGY,
    'intuitions_open': $INTUITION_COUNT,
    'dream_health': '$DREAM_SCORE',
    'recent_handoffs': $RECENT_HANDOFFS,
    'ts': datetime.now().isoformat()
}
# Append to log
log = []
if os.path.exists('$PREDICTION_LOG'):
    try:
        with open('$PREDICTION_LOG') as f:
            log = json.load(f)
    except: log = []
log.append(entry)
# Keep last 30 entries
log = log[-30:]
with open('$PREDICTION_LOG', 'w') as f:
    json.dump(log, f, indent=2)
" 2>/dev/null || true

echo "$BRIEF"
