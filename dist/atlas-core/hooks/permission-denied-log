#!/bin/bash
# Hook: PermissionRequest — Log permission events for rule improvement
# Captures tool name and context for analytics
# Exit 0 always (never interfere with permission flow)
set -euo pipefail

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // "unknown"')
ACTION=$(echo "$INPUT" | jq -r '.action // "unknown"')
CMD=$(echo "$INPUT" | jq -r '.tool_input.command // .tool_input.file_path // "n/a"' 2>/dev/null | head -c 200)
TIMESTAMP=$(date -u '+%Y-%m-%dT%H:%M:%SZ')

LOG_FILE="$HOME/.claude/permission-log.jsonl"
echo "{\"ts\":\"$TIMESTAMP\",\"tool\":\"$TOOL\",\"action\":\"$ACTION\",\"input\":\"$CMD\"}" \
  >> "$LOG_FILE" 2>/dev/null

exit 0
