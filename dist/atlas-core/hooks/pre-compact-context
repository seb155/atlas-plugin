#!/bin/bash
# Hook PreCompact — Inject dynamic context before auto-compaction
# Triggered BEFORE Claude summarizes the conversation
# stdout -> injected as additional context for the summarizer
# Migrated from ~/.claude/hooks/pre-compact.sh
# Exit 0 = OK (never block compaction)
set -euo pipefail

INPUT=$(cat)
TRIGGER=$(echo "$INPUT" | jq -r '.trigger // "unknown"')
TIMESTAMP=$(date '+%Y-%m-%d %H:%M %Z')

# --- Log compaction event ---
LOG_FILE="$HOME/.claude/compaction-log.txt"
echo "[$TIMESTAMP] Compaction ($TRIGGER)" >> "$LOG_FILE"

# --- Dynamic context: git state ---
BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
MODIFIED=$(git diff --name-only 2>/dev/null | head -20 || true)
STAGED=$(git diff --cached --name-only 2>/dev/null | head -20 || true)

echo "=== CONTEXT TO PRESERVE DURING COMPACTION ==="
echo ""
echo "Active branch: $BRANCH"

if [ -n "$MODIFIED" ]; then
  echo ""
  echo "Modified files (unstaged):"
  echo "$MODIFIED"
fi

if [ -n "$STAGED" ]; then
  echo ""
  echo "Staged files:"
  echo "$STAGED"
fi

echo ""
echo "IMPORTANT — Preserve in summary:"
echo "- All working test commands used in this session"
echo "- Current error/bug context (description + file path)"
echo "- Architectural decisions made during this session"
echo "- Sprint status and active task progress"
echo "- Active worktree path if any"

exit 0
