#!/usr/bin/env bash
# ATLAS Workflow Intent Detect Hook (v6.1.0)
#
# UserPromptSubmit hook — regex + keyword intent matcher against workflow-registry.
# Emits non-blocking suggestion via additionalContext if confidence ≥ 0.7.
# Fail-open (timeout 50ms) — never blocks user prompt.
#
# Plan ref: Section N.1 (user_intent detection)
# Task: v6.1-tasks.md 7.9

set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
REGISTRY="${PLUGIN_ROOT}/scripts/execution-philosophy/workflow-registry.yaml"

# Fail-open if registry missing
if [[ ! -f "$REGISTRY" ]]; then
  echo '{"continue":true}'
  exit 0
fi

INPUT=$(cat 2>/dev/null || echo '{}')

# Extract user prompt (first 200 chars)
PROMPT=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    p = d.get('prompt', '') or d.get('input', '')
    print(str(p).strip()[:200].lower())
except Exception:
    print('')
" <<<"$INPUT" 2>/dev/null)

if [[ -z "$PROMPT" ]]; then
  echo '{"continue":true}'
  exit 0
fi

# Match against registry triggers (confidence = keyword overlap)
MATCH=$(timeout 2 python3 <<PYEOF 2>/dev/null
import yaml, sys, re

try:
    with open("$REGISTRY") as f:
        d = yaml.safe_load(f)
except Exception:
    sys.exit(0)

prompt = """$PROMPT"""
best_match = None
best_score = 0.0

for w in d.get('workflows', []):
    triggers = w.get('triggers', [])
    if not triggers:
        continue
    for t in triggers:
        # Simple substring match (case-insensitive, lowercased prompt)
        if t.lower() in prompt:
            # Score = len of trigger / len of prompt, capped at 1.0
            score = min(1.0, len(t) / max(len(prompt), 1) * 5)
            if score > best_score:
                best_score = score
                best_match = w

# Confidence threshold
if best_match and best_score >= 0.3:
    print(f"{best_match['name']}|{best_score:.2f}|{best_match.get('category', '?')}")
PYEOF
)

if [[ -z "$MATCH" ]]; then
  echo '{"continue":true}'
  exit 0
fi

WORKFLOW=$(echo "$MATCH" | cut -d'|' -f1)
CONFIDENCE=$(echo "$MATCH" | cut -d'|' -f2)
CATEGORY=$(echo "$MATCH" | cut -d'|' -f3)

REMINDER="💡 Intent detected: workflow '${WORKFLOW}' (${CATEGORY}, confidence ${CONFIDENCE}). Consider /atlas workflow ${CATEGORY}/${WORKFLOW#workflow-} to activate its step chain with Iron Law enforcement. (Ignore this if not applicable.)"

python3 <<PYEOF 2>/dev/null || true
import json
print(json.dumps({
    "hookSpecificOutput": {
        "hookEventName": "UserPromptSubmit",
        "additionalContext": """${REMINDER}"""
    }
}))
PYEOF

exit 0
