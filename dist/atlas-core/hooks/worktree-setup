#!/usr/bin/env bash
# ATLAS Hook: WorktreeCreate handler (CC v2.1.50+)
#
# Fires when Claude Code creates a new git worktree (via `claude -w <name>`
# or EnterWorktree tool). Logs the event and prepares the new worktree:
# - Validates name (delegates to enforce-worktree-name if available)
# - Symlinks .env or copies CLAUDE.md/rules from parent repo
# - Appends to ~/.atlas/logs/worktree-events.log for audit

set -euo pipefail

readonly LOG_FILE="${HOME}/.atlas/logs/worktree-events.log"
readonly STDIN_JSON="$(cat 2>/dev/null || echo '{}')"

mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true

# Parse worktree path + branch from JSON input (if jq available)
WORKTREE_PATH=""
WORKTREE_BRANCH=""
if command -v jq >/dev/null 2>&1; then
  WORKTREE_PATH="$(echo "$STDIN_JSON" | jq -r '.worktree.path // .worktreePath // ""' 2>/dev/null || echo "")"
  WORKTREE_BRANCH="$(echo "$STDIN_JSON" | jq -r '.worktree.branch // .worktreeBranch // ""' 2>/dev/null || echo "")"
fi

# Log event (structured for downstream parsing)
{
  printf '{"ts":"%s","event":"WorktreeCreate","path":"%s","branch":"%s"}\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "${WORKTREE_PATH}" \
    "${WORKTREE_BRANCH}"
} >> "$LOG_FILE" 2>/dev/null || true

exit 0
