#!/usr/bin/env bash
# ATLAS Focus Guard — context-switch and energy alert hook
# Fires on UserPromptSubmit. Tracks switches and energy signals.
# Respects ATLAS_LEARNING_VERBOSITY (1=silent, 2=semi, 3=full).
set -euo pipefail

# Hook aggregation log
_hook_log() {
  local result="${1:-pass}"
  local elapsed="${2:-0}"
  printf '{"ts":"%s","event":"%s","handler":"%s","result":"%s","ms":%s}\n' \
    "$(date -Iseconds)" "${HOOK_EVENT:-UserPromptSubmit}" "$(basename "$0")" "$result" "$elapsed" \
    >> "${HOME}/.claude/hook-log.jsonl" 2>/dev/null
}

VERBOSITY="${ATLAS_LEARNING_VERBOSITY:-2}"
[ "$VERBOSITY" -lt 2 ] 2>/dev/null && exit 0  # Silent mode — skip

INPUT=$(cat)
PROMPT=$(echo "$INPUT" | jq -r '.prompt // empty' 2>/dev/null)
[ -z "$PROMPT" ] || [ ${#PROMPT} -lt 5 ] && exit 0

COUNTER_FILE="${HOME}/.claude/atlas-focus-guard.json"
MAX_WARNINGS=2

# Read or init counter
if [ -f "$COUNTER_FILE" ]; then
  WARNINGS=$(python3 -c "import json; print(json.load(open('$COUNTER_FILE')).get('warnings',0))" 2>/dev/null || echo "0")
  SWITCHES=$(python3 -c "import json; print(json.load(open('$COUNTER_FILE')).get('switches',0))" 2>/dev/null || echo "0")
  LAST_TOPIC=$(python3 -c "import json; print(json.load(open('$COUNTER_FILE')).get('last_topic',''))" 2>/dev/null || echo "")
else
  WARNINGS=0
  SWITCHES=0
  LAST_TOPIC=""
fi

# Check if we've hit the warning limit
[ "$WARNINGS" -ge "$MAX_WARNINGS" ] && exit 0

CURRENT_TOPIC="${ATLAS_TOPIC:-}"
MSG=""

# Detect topic switch
if [ -n "$CURRENT_TOPIC" ] && [ -n "$LAST_TOPIC" ] && [ "$CURRENT_TOPIC" != "$LAST_TOPIC" ]; then
  SWITCHES=$((SWITCHES + 1))
  if [ "$SWITCHES" -ge 3 ]; then
    MSG="ATLAS | FOCUS | ${SWITCHES} context switches detected this session. Consider finishing current topic before switching."
    WARNINGS=$((WARNINGS + 1))
  fi
fi

# Detect low energy signals
SIGNALS_FILE="${HOME}/.claude/atlas-experiential-signals.json"
if [ -f "$SIGNALS_FILE" ]; then
  LOW_ENERGY=$(python3 -c "
import json
try:
    d = json.load(open('$SIGNALS_FILE'))
    low = sum(1 for s in d.get('signals',[]) if s.get('type')=='energy' and s.get('value',5) <= 2)
    print(low)
except: print(0)
" 2>/dev/null || echo "0")

  if [ "$LOW_ENERGY" -ge 3 ] && [ -z "$MSG" ]; then
    MSG="ATLAS | ENERGY | Low energy detected (${LOW_ENERGY} signals). Consider a break or lighter tasks."
    WARNINGS=$((WARNINGS + 1))
  fi
fi

# Save state
python3 -c "
import json
data = {'warnings': $WARNINGS, 'switches': $SWITCHES, 'last_topic': '${CURRENT_TOPIC}'}
with open('$COUNTER_FILE', 'w') as f:
    json.dump(data, f)
" 2>/dev/null

# Output message if any
if [ -n "$MSG" ]; then
  echo "$MSG"
fi
_hook_log pass
