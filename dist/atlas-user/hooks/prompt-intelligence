#!/usr/bin/env bash
# ATLAS Plugin — Prompt Intelligence Hook (UserPromptSubmit)
# Proactive suggestions based on user prompt content.
# Runs async, stdout = shown to user as system-reminder.
#
# R7: Feature-board proactive — suggest /atlas board when working on features
# R8: Pipeline enforcement — remind when skipping steps
#
# Input: JSON on stdin with prompt text
# Must complete in <3s

set -o pipefail
trap 'exit 0' ERR

# Throttle: avoid repeating the same suggestion
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$HOOK_DIR/lib/throttle.sh" 2>/dev/null || true

# Read prompt from stdin
INPUT=$(cat 2>/dev/null || echo '{}')
PROMPT=$(echo "$INPUT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('prompt', d.get('message', '')))" 2>/dev/null || echo "")

[ -z "$PROMPT" ] && exit 0

# Lowercase for matching
PROMPT_LC=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]')

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# R7: Feature-board proactive
# When user mentions features, check WIP count
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if echo "$PROMPT_LC" | grep -qP '(new feature|add feature|feat\(|feature request|nouvelle fonctionnalit)'; then
  if [ -f ".blueprint/FEATURES.md" ]; then
    WIP=$(grep -c "IN_PROGRESS" ".blueprint/FEATURES.md" 2>/dev/null || echo 0)
    if [ "$WIP" -gt 10 ] && type throttle_check &>/dev/null && throttle_check "feature-board-suggest" 600; then
      echo "📌 ATLAS │ WIP=${WIP} features in progress. Consider /atlas board wip to check capacity before adding more."
    fi
  fi
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# R8: Pipeline enforcement
# Detect when user skips planning or verification steps
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Pattern: "implement X" / "code X" / "build X" without plan
if echo "$PROMPT_LC" | grep -qP '(implement|code|build|create|add)\s+(the|a|this|new)?\s*\w+' ; then
  # Check if there's an active plan in .blueprint/plans/
  RECENT_PLAN=$(find .blueprint/plans/ -name "*.md" -mmin -120 2>/dev/null | head -1)
  if [ -z "$RECENT_PLAN" ] && type throttle_check &>/dev/null && throttle_check "pipeline-plan-remind" 1800; then
    echo "🏗️ ATLAS │ No recent plan found. Consider context-discovery + plan-builder before implementing. Skip if this is a quick fix."
  fi
fi

# Pattern: "push" / "ship" / "merge" / "deploy" without verify
if echo "$PROMPT_LC" | grep -qP '(push|ship|merge|deploy|release|publish)'; then
  # Check if verification was run recently (look for test results in current dir)
  RECENT_TEST=$(find . -name "*.test-results" -o -name "test-output.txt" -mmin -60 2>/dev/null | head -1)
  if [ -z "$RECENT_TEST" ] && type throttle_check &>/dev/null && throttle_check "pipeline-verify-remind" 1800; then
    echo "📊 ATLAS │ Shipping without recent test run? Consider /atlas verify first."
  fi
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# R10: Dynamic skill triggers (from _metadata.yaml)
# Skills declare their own triggers — no hardcoding needed
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Locate _metadata.yaml (plugin root)
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(dirname "$HOOK_DIR")}"
METADATA_FILE="$PLUGIN_ROOT/skills/_metadata.yaml"

if [ -f "$METADATA_FILE" ]; then
  # Cache trigger map (rebuild if metadata changes)
  CACHE_KEY=$(stat -c %Y "$METADATA_FILE" 2>/dev/null || stat -f %m "$METADATA_FILE" 2>/dev/null || echo "0")
  TRIGGER_CACHE="/tmp/.atlas-trigger-cache-${CACHE_KEY}"

  if [ ! -f "$TRIGGER_CACHE" ]; then
    # Build trigger→skill mapping: "trigger_phrase|skill_name" per line
    python3 -c "
import yaml, sys
with open('$METADATA_FILE') as f:
    data = yaml.safe_load(f)
skills = data.get('skills', {})
for name, meta in skills.items():
    triggers = meta.get('triggers', [])
    for t in triggers:
        print(f'{t.lower()}|{name}')
" > "$TRIGGER_CACHE" 2>/dev/null || true
  fi

  # Match prompt against cached triggers (max 1 suggestion)
  if [ -f "$TRIGGER_CACHE" ] && [ -s "$TRIGGER_CACHE" ]; then
    MATCHED_SKILL=""
    while IFS='|' read -r trigger skill; do
      if echo "$PROMPT_LC" | grep -qiF "$trigger"; then
        MATCHED_SKILL="$skill"
        break
      fi
    done < "$TRIGGER_CACHE"

    if [ -n "$MATCHED_SKILL" ] && type throttle_check &>/dev/null && throttle_check "trigger-$MATCHED_SKILL" 300; then
      # Look up emoji from metadata
      SKILL_EMOJI=$(grep -A2 "^  ${MATCHED_SKILL}:" "$METADATA_FILE" | grep "emoji:" | head -1 | sed 's/.*emoji: "\(.*\)"/\1/' || echo "🔧")
      echo "💡 ATLAS │ SKILL MATCH │ ${SKILL_EMOJI} ${MATCHED_SKILL} — use /atlas-admin:${MATCHED_SKILL} or just describe what you need"
    fi
  fi
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# R9: Experiential context — relationship surfacing
# When a person name matches a relationship memory file,
# inject strengths + last interaction (rate-limited)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

EXP_COUNTER_FILE="$HOME/.claude/atlas-exp-inject-count.txt"

# Read + increment counter (reset every 5 prompts)
EXP_COUNT=0
if [ -f "$EXP_COUNTER_FILE" ]; then
  EXP_COUNT=$(cat "$EXP_COUNTER_FILE" 2>/dev/null || echo 0)
fi
EXP_COUNT=$((EXP_COUNT + 1))
if [ "$EXP_COUNT" -ge 5 ]; then
  EXP_COUNT=0
fi
echo "$EXP_COUNT" > "$EXP_COUNTER_FILE"

# Only inject if counter == 1 (once per 5-prompt window)
if [ "$EXP_COUNT" -eq 1 ]; then

  MEMORY_DIR="$HOME/.claude/projects/-home-sgagnon-workspace-atlas-projects-atlas-synapse/memory"

  # R9a: Relationship surfacing — match person names from relationship files
  for REL_FILE in "$MEMORY_DIR"/relationship-*.md; do
    [ -f "$REL_FILE" ] || continue
    # Extract person name from filename: relationship-seb-gagnon.md → seb gagnon
    PERSON_SLUG=$(basename "$REL_FILE" .md | sed 's/^relationship-//' | tr '-' ' ')
    if echo "$PROMPT_LC" | grep -qi "$PERSON_SLUG"; then
      STRENGTHS=$(grep -i 'strengths\|expertise\|skills' "$REL_FILE" 2>/dev/null | head -1 | sed 's/^[#*: -]*//' | cut -c1-80)
      LAST_INT=$(grep -i 'last.interaction\|last.contact\|last.seen' "$REL_FILE" 2>/dev/null | head -1 | sed 's/^[#*: -]*//' | cut -c1-40)
      [ -n "$STRENGTHS" ] && echo "🧠 ATLAS │ RELATIONSHIP │ ${PERSON_SLUG}: ${STRENGTHS}. ${LAST_INT:+Last: $LAST_INT}"
      break  # Max 1 injection
    fi
  done

  # R9b: Decision context — detect decision keywords and surface similar past decisions
  if echo "$PROMPT_LC" | grep -qP '(should we|choose|option [a-d]|which approach|quelle approche|lequel|choisir|decide|trade.?off)'; then
    # Search recent episodes for decision-related content
    DECISION_HIT=""
    for EP_FILE in "$MEMORY_DIR"/episode-*.md; do
      [ -f "$EP_FILE" ] || continue
      MATCH=$(grep -il 'decision\|chose\|selected\|picked\|went with' "$EP_FILE" 2>/dev/null)
      if [ -n "$MATCH" ]; then
        EP_DATE=$(grep -i 'date\|created' "$EP_FILE" 2>/dev/null | head -1 | grep -oP '\d{4}-\d{2}-\d{2}' | head -1)
        EP_CONF=$(grep -i 'confidence' "$EP_FILE" 2>/dev/null | head -1 | grep -oP '[\d.]+' | head -1)
        EP_OUTCOME=$(grep -i 'outcome\|result' "$EP_FILE" 2>/dev/null | head -1 | sed 's/^[#*: -]*//' | cut -c1-60)
        if [ -n "$EP_DATE" ] || [ -n "$EP_OUTCOME" ]; then
          echo "🔮 ATLAS │ DECISION │ Similar choice on ${EP_DATE:-unknown}. ${EP_CONF:+Confidence: $EP_CONF.} ${EP_OUTCOME:+Outcome: $EP_OUTCOME}"
          break  # Max 1 injection total
        fi
      fi
    done
  fi

fi

exit 0
