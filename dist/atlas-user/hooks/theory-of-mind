#!/usr/bin/env bash
# theory-of-mind вЂ” User Cognitive State Inference (SP-COGNITION Gap #3)
# Event: UserPromptSubmit (sync) | Detects: frustrated, curious, fatigued, flow, decision_fatigue
#
# Analyzes the current prompt with 3 signal layers:
#   1. Regex patterns (bilingual FR/EN/QC)
#   2. Statistical baseline (message length vs historical average)
#   3. Temporal context (time of day, session position)
#
# Output: system-reminder with inferred state + behavioral guidance
# State file: ~/.claude/atlas-tom-state.json (for downstream hooks)
# Must complete in <3s

set -o pipefail
trap 'exit 0' ERR

_START_MS=$(date +%s%N 2>/dev/null | head -c13 || echo "0")

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$HOOK_DIR/lib/throttle.sh" 2>/dev/null || true

# Hook aggregation log
_hook_log() {
  local result="${1:-pass}"
  local end_ms
  end_ms=$(date +%s%N 2>/dev/null | head -c13 || echo "0")
  local elapsed=$(( end_ms - _START_MS ))
  printf '{"ts":"%s","event":"%s","handler":"%s","result":"%s","ms":%s}\n' \
    "$(date -Iseconds)" "${HOOK_EVENT:-UserPromptSubmit}" "$(basename "$0")" "$result" "$elapsed" \
    >> "${HOME}/.claude/hook-log.jsonl" 2>/dev/null || true
}

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 1. Read prompt from stdin
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
INPUT=$(cat 2>/dev/null || echo '{}')
PROMPT=$(echo "$INPUT" | jq -r '.prompt // .message // empty' 2>/dev/null || echo "")

if [ -z "$PROMPT" ] || [ ${#PROMPT} -lt 3 ]; then
  _hook_log "skip:short"
  exit 0
fi

# в”Ђв”Ђ Fast-exit for simple commands (< 500ms) в”Ђв”Ђ
# Slash commands, numbers, single words, git ops вЂ” skip full cognitive analysis
PROMPT_TRIMMED=$(echo "$PROMPT" | tr -d '[:space:]')
if [ ${#PROMPT_TRIMMED} -le 30 ]; then
  if echo "$PROMPT" | grep -qE '^(/[a-z-]+|[0-9]+|y|yes|oui|ok|continue|go|done|stop|exit|quit|git |make |bun |docker )'; then
    _hook_log "skip:simple-cmd"
    exit 0
  fi
fi

PROMPT_LEN=${#PROMPT}
PROMPT_LOWER=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]')

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 2. Regex pattern matching вЂ” 5 cognitive states
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

SCORE_FRUSTRATED=0
SCORE_CURIOUS=0
SCORE_FATIGUED=0
SCORE_FLOW=0
SCORE_DECISION_FATIGUE=0

# --- Frustration (FR/EN/QC) ---
if echo "$PROMPT_LOWER" | grep -qE "(juste fais|just do it|fais-le|do it already|arr[eГЄ]te de |arr[eГЄ]te [Г§c]a)"; then
  SCORE_FRUSTRATED=$((SCORE_FRUSTRATED + 3))
fi
if echo "$PROMPT_LOWER" | grep -qE "(calice|cГўlice|tabarn|maudit|crisse|osti|ciboire|sacrament)"; then
  SCORE_FRUSTRATED=$((SCORE_FRUSTRATED + 4))
fi
if echo "$PROMPT_LOWER" | grep -qE "^(non|no|stop|ugh|nope|pas Г§a)[.!,]*$"; then
  SCORE_FRUSTRATED=$((SCORE_FRUSTRATED + 3))
fi
if echo "$PROMPT_LOWER" | grep -qE "(j'ai dit|i said|already told you|je t'ai dit|encore|again[!?])"; then
  SCORE_FRUSTRATED=$((SCORE_FRUSTRATED + 2))
fi
# Short imperative messages boost frustration
if [ "$PROMPT_LEN" -lt 30 ] && echo "$PROMPT_LOWER" | grep -qE "(fais|do |fix |change |delete |remove )"; then
  SCORE_FRUSTRATED=$((SCORE_FRUSTRATED + 1))
fi

# --- Curiosity ---
if echo "$PROMPT_LOWER" | grep -qE "(pourquoi|why |explain|explique|how does|comment [Г§c]a)"; then
  SCORE_CURIOUS=$((SCORE_CURIOUS + 3))
fi
if echo "$PROMPT_LOWER" | grep -qE "(what if|et si |interesting|fascinating|tell me more|curieux|curious)"; then
  SCORE_CURIOUS=$((SCORE_CURIOUS + 2))
fi
if echo "$PROMPT_LOWER" | grep -qE "(c'est quoi|what is|qu'est-ce|how come|how would|comment on)"; then
  SCORE_CURIOUS=$((SCORE_CURIOUS + 2))
fi
# Long messages with question marks boost curiosity
if [ "$PROMPT_LEN" -gt 80 ] && echo "$PROMPT" | grep -qE "\?.*\?"; then
  SCORE_CURIOUS=$((SCORE_CURIOUS + 2))
fi

# --- Fatigue ---
if echo "$PROMPT_LOWER" | grep -qE "(fatiguГ©|fatigue|tired|exhausted|Г©puisГ©|epuise|j.?en peux plus)"; then
  SCORE_FATIGUED=$((SCORE_FATIGUED + 4))
fi
if echo "$PROMPT_LOWER" | grep -qE "(j'arr[eГЄ]te|i'm done|enough for|fini pour|bonne nuit|good night|on arrete)"; then
  SCORE_FATIGUED=$((SCORE_FATIGUED + 3))
fi
if echo "$PROMPT_LOWER" | grep -qE "(dernier truc|last thing|one more|un dernier|avant de partir)"; then
  SCORE_FATIGUED=$((SCORE_FATIGUED + 1))
fi

# --- Flow (code-heavy, focused) ---
# Count code markers in the prompt
CODE_MARKERS=$(echo "$PROMPT" | { grep -oE '(```|/[a-z_-]+/[a-z_-]+|function |def |class |import |const |let |export )' || true; } | wc -l)
if [ "$CODE_MARKERS" -ge 3 ]; then
  SCORE_FLOW=$((SCORE_FLOW + 3))
fi
# File paths suggest focused technical work
if echo "$PROMPT" | grep -qE '(\./|~/|/home/|src/|hooks/|tests/)'; then
  SCORE_FLOW=$((SCORE_FLOW + 1))
fi
# Single-word technical commands
if echo "$PROMPT_LOWER" | grep -qE "^(/[a-z-]+|git |make |bun |docker |pytest )"; then
  SCORE_FLOW=$((SCORE_FLOW + 2))
fi

# --- Decision fatigue ---
if echo "$PROMPT_LOWER" | grep -qE "^(oui|yes|ok|yep|ouais|yea|sure|d'accord)[.!]*$"; then
  SCORE_DECISION_FATIGUE=$((SCORE_DECISION_FATIGUE + 2))
fi
if echo "$PROMPT_LOWER" | grep -qE "(whatever|je m'en fous|peu importe|i don't care|choose for me|dГ©cide|tu choisis)"; then
  SCORE_DECISION_FATIGUE=$((SCORE_DECISION_FATIGUE + 4))
fi
if echo "$PROMPT_LOWER" | grep -qE "(go ahead|vas-y|lance|do it|proceed|continue)$"; then
  SCORE_DECISION_FATIGUE=$((SCORE_DECISION_FATIGUE + 1))
fi

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 3. Statistical baseline (from TOM history)
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

TOM_LOG="$HOME/.claude/atlas-tom-signals.json"
CALIBRATED="false"
AVG_LEN=100
ENTRY_COUNT=0

if [ -f "$TOM_LOG" ] && [ -s "$TOM_LOG" ]; then
  STATS=$(python3 -c "
import json
try:
    with open('$TOM_LOG') as f:
        log = json.load(f)
    count = len(log)
    if count >= 5:
        avg = sum(e.get('length', 100) for e in log) / count
        calibrated = 'true' if count >= 30 else 'false'
        # Recent trend: last 5 messages
        recent = log[-5:]
        recent_avg = sum(e.get('length', 100) for e in recent) / len(recent)
        # Decreasing trend boosts fatigue
        trend = 'decreasing' if recent_avg < avg * 0.6 else 'stable'
        # Count recent short approvals (decision fatigue)
        short_count = sum(1 for e in recent if e.get('length', 100) < 15)
        print(f'{avg:.0f}|{calibrated}|{count}|{trend}|{short_count}')
    else:
        print(f'100|false|{count}|stable|0')
except:
    print('100|false|0|stable|0')
" 2>/dev/null || echo "100|false|0|stable|0")

  AVG_LEN=$(echo "$STATS" | cut -d'|' -f1)
  CALIBRATED=$(echo "$STATS" | cut -d'|' -f2)
  ENTRY_COUNT=$(echo "$STATS" | cut -d'|' -f3)
  TREND=$(echo "$STATS" | cut -d'|' -f4)
  SHORT_COUNT=$(echo "$STATS" | cut -d'|' -f5)

  # Statistical boosts
  if [ "$TREND" = "decreasing" ]; then
    SCORE_FATIGUED=$((SCORE_FATIGUED + 2))
  fi
  if [ "${SHORT_COUNT:-0}" -ge 3 ]; then
    SCORE_DECISION_FATIGUE=$((SCORE_DECISION_FATIGUE + 3))
  fi
fi

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 4. Temporal signals
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

HOUR=$(date +%H)

# Late night boosts fatigue
if [ "$HOUR" -ge 22 ] || [ "$HOUR" -lt 5 ]; then
  SCORE_FATIGUED=$((SCORE_FATIGUED + 2))
fi
# Early morning can reduce curiosity threshold
if [ "$HOUR" -ge 6 ] && [ "$HOUR" -lt 10 ]; then
  SCORE_CURIOUS=$((SCORE_CURIOUS + 1))  # Morning = exploration time
fi

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 5. Multi-signal scoring вЂ” determine top state
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

# Threshold: need at least 3 points to infer a state
STATE="standard"
CONFIDENCE=0
GUIDANCE=""

# Find highest scoring state (min threshold: 3)
MAX_SCORE=2  # Must beat this

if [ "$SCORE_FRUSTRATED" -gt "$MAX_SCORE" ]; then
  MAX_SCORE=$SCORE_FRUSTRATED; STATE="frustrated"
fi
if [ "$SCORE_CURIOUS" -gt "$MAX_SCORE" ]; then
  MAX_SCORE=$SCORE_CURIOUS; STATE="curious"
fi
if [ "$SCORE_FATIGUED" -gt "$MAX_SCORE" ]; then
  MAX_SCORE=$SCORE_FATIGUED; STATE="fatigued"
fi
if [ "$SCORE_FLOW" -gt "$MAX_SCORE" ]; then
  MAX_SCORE=$SCORE_FLOW; STATE="flow"
fi
if [ "$SCORE_DECISION_FATIGUE" -gt "$MAX_SCORE" ]; then
  MAX_SCORE=$SCORE_DECISION_FATIGUE; STATE="decision_fatigue"
fi

# Compute confidence (0.0-1.0) based on score strength
if [ "$MAX_SCORE" -ge 6 ]; then
  CONFIDENCE="0.90"
elif [ "$MAX_SCORE" -ge 5 ]; then
  CONFIDENCE="0.82"
elif [ "$MAX_SCORE" -ge 4 ]; then
  CONFIDENCE="0.75"
elif [ "$MAX_SCORE" -ge 3 ]; then
  CONFIDENCE="0.65"
fi

# Map state to behavioral guidance
case "$STATE" in
  frustrated)    GUIDANCE="Actions directes, skip questions et Insights." ;;
  curious)       GUIDANCE="Enrichir explications, explorer alternatives." ;;
  fatigued)      GUIDANCE="Simplifier, suggГ©rer pause si fin de session." ;;
  flow)          GUIDANCE="Minimal output, zero commentary, execute." ;;
  decision_fatigue) GUIDANCE="Max 2 options, recommander un choix." ;;
esac

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 6. Append to TOM signal history (extend existing format)
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

python3 -c "
import json, os
from datetime import datetime
entry = {
    'ts': datetime.now().isoformat(),
    'hour': $HOUR,
    'length': $PROMPT_LEN,
    'state': '$STATE',
    'confidence': float('$CONFIDENCE') if '$CONFIDENCE' != '0' else 0.0,
    'scores': {
        'frustrated': $SCORE_FRUSTRATED,
        'curious': $SCORE_CURIOUS,
        'fatigued': $SCORE_FATIGUED,
        'flow': $SCORE_FLOW,
        'decision_fatigue': $SCORE_DECISION_FATIGUE
    }
}
log = []
if os.path.exists('$TOM_LOG'):
    try:
        with open('$TOM_LOG') as f:
            log = json.load(f)
    except: log = []
log.append(entry)
log = log[-200:]  # keep last 200 entries
with open('$TOM_LOG', 'w') as f:
    json.dump(log, f)
" 2>/dev/null || true

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 7. Write current state file (for downstream hooks)
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

TOM_STATE="$HOME/.claude/atlas-tom-state.json"
python3 -c "
import json
from datetime import datetime
state = {
    'state': '$STATE',
    'confidence': float('$CONFIDENCE') if '$CONFIDENCE' != '0' else 0.0,
    'guidance': '$GUIDANCE',
    'scores': {
        'frustrated': $SCORE_FRUSTRATED,
        'curious': $SCORE_CURIOUS,
        'fatigued': $SCORE_FATIGUED,
        'flow': $SCORE_FLOW,
        'decision_fatigue': $SCORE_DECISION_FATIGUE
    },
    'prompt_length': $PROMPT_LEN,
    'calibrated': '$CALIBRATED' == 'true',
    'entry_count': int('${ENTRY_COUNT:-0}'),
    'updated': datetime.now().isoformat()
}
with open('$TOM_STATE', 'w') as f:
    json.dump(state, f, indent=2)
" 2>/dev/null || true

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
# 8. Inject system-reminder (only non-standard + confident)
# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

if [ "$STATE" != "standard" ]; then
  # Throttle: max 1 injection per 3 minutes
  if type throttle_check &>/dev/null && ! throttle_check "tom-state" 180; then
    _hook_log "throttled:${STATE}"
    exit 0
  fi

  # Format confidence as percentage
  CONF_PCT=$(python3 -c "print(f'{float(\"$CONFIDENCE\")*100:.0f}')" 2>/dev/null || echo "65")
  echo "рџ§  ToM: ${STATE} (${CONF_PCT}%) вЂ” ${GUIDANCE}"
fi

_hook_log "pass:${STATE}:${CONFIDENCE}"
