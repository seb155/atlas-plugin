#!/bin/bash
# Hook PostToolUse (Edit/Write) — Lint TypeScript files after edit
# Only runs for .ts/.tsx files in synapse project
# Walks UP directory tree to find biome.json
# Migrated from ~/.claude/hooks/post-edit-lint.sh
# Exit 0 = OK, no blocking
set -euo pipefail

INPUT=$(cat)
FILE=$(echo "$INPUT" | jq -r '.tool_input.file_path // .tool_input.filePath // empty' || true)

# Skip if no file or not a TS file
[ -z "$FILE" ] && exit 0
echo "$FILE" | grep -qE '\.(ts|tsx)$' || exit 0

# Only lint synapse files
echo "$FILE" | grep -q "synapse" || exit 0

# Walk up directory tree to find biome.json
find_biome_config() {
  local dir="$1"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/biome.json" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

# Check if biome is available and config exists
if command -v bunx &>/dev/null; then
  BIOME_DIR=$(find_biome_config "$(dirname "$FILE")")
  if [ -n "$BIOME_DIR" ]; then
    cd "$BIOME_DIR" && bunx biome check --apply "$FILE" 2>/dev/null || true
  fi
fi

exit 0
