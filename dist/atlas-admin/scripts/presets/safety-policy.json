{
  "$schema": "atlas-safety-policy-v1",
  "$comment": "Mandatory security deny rules applied to ALL developers during onboarding. These cannot be overridden by user preferences.",
  "deny_rules": [
    "Bash(rm -rf /*)",
    "Bash(rm -rf /)",
    "Bash(sudo rm -rf /*)",
    "Bash(mkfs *)",
    "Bash(dd if=/dev/zero of=/dev/ *)"
  ],
  "project_deny_rules": {
    "$comment": "Applied per-project in .claude/settings.json (not global)",
    "synapse": [
      "Bash(git commit --no-verify:*)",
      "Bash(git commit * --no-verify:*)"
    ]
  },
  "required_settings": {
    "$comment": "Settings that must exist in ~/.claude/settings.json",
    "language": "francais",
    "autoUpdatesChannel": "latest"
  },
  "forbidden_settings_keys": {
    "$comment": "Keys that must NOT exist in ~/.claude/settings.json (managed by plugin)",
    "keys": ["hooks"]
  }
}
