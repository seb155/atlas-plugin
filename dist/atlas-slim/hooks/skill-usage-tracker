#!/bin/bash
# Hook: PostToolUse(Skill) — Track skill invocation for usage analytics
# Appends one JSON line per skill invocation to ~/.atlas/skill-usage.jsonl
# Used by: `atlas plugin usage` and dream Phase 2.7 (Workflow Audit)
# Exit 0 always (never block)

INPUT=$(cat)
SKILL_NAME=$(echo "$INPUT" | jq -r '.tool_input.skill // "unknown"')
SKILL_ARGS=$(echo "$INPUT" | jq -r '.tool_input.args // ""')
TIMESTAMP=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
SESSION_ID="${CLAUDE_SESSION_ID:-unknown}"

# Ensure directory exists
mkdir -p "$HOME/.atlas" 2>/dev/null

LOG_FILE="$HOME/.atlas/skill-usage.jsonl"
echo "{\"ts\":\"$TIMESTAMP\",\"skill\":\"$SKILL_NAME\",\"args\":\"$SKILL_ARGS\",\"session\":\"$SESSION_ID\"}" \
  >> "$LOG_FILE" 2>/dev/null

exit 0
